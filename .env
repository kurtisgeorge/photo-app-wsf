# A strong, random string is best for the JWT secret.
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-and-long-jwt-secret-key

# Google OAuth 2.0 Credentials
# Replace with your actual credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AES-256 Encryption Key (64-char hex = 32 bytes)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=bd2803f3423d71196103fa638bc7d4f2f1fca7717775eec08485f2bb80ef8ca5
